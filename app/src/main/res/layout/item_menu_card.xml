<?xml version="1.0" encoding="utf-8"?>
<!--
    Item kartu menu untuk RecyclerView grid 2 kolom di MenuActivity.
    Set di Adapter dengan GridLayoutManager(context, 2).
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="5dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Foto Menu -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="110dp"
            android:background="@color/soft_red">

            <ImageView
                android:id="@+id/imgMenu"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/ic_food_placeholder"/>

            <!-- Overlay badge Habis -->
            <TextView
                android:id="@+id/tvHabisOverlay"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="HABIS"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/white"
                android:background="#AA000000"
                android:letterSpacing="0.1"
                android:visibility="gone"/>
        </FrameLayout>

        <!-- Body kartu -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="10dp">

            <TextView
                android:id="@+id/tvMenuName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Ayam Taliwang"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:maxLines="1"
                android:ellipsize="end"
                android:layout_marginBottom="2dp"/>

            <TextView
                android:id="@+id/tvMenuPrice"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 35.000"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/primary"
                android:layout_marginBottom="1dp"/>

            <TextView
                android:id="@+id/tvMenuKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Makanan"
                android:textSize="10sp"
                android:textColor="@color/text_tertiary"
                android:layout_marginBottom="8dp"/>

            <!-- Toggle + Edit -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Toggle Switch -->
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switchAvailable"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:layout_marginEnd="4dp"
                    app:thumbTint="@color/toggle_thumb_selector"
                    app:trackTint="@color/toggle_track_selector"/>

                <TextView
                    android:id="@+id/tvAvailableLabel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Tersedia"
                    android:textSize="10sp"
                    android:textColor="@color/toggle_on"/>

                <!-- Edit -->
                <ImageButton
                    android:id="@+id/btnEdit"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_edit"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/text_secondary"
                    android:layout_marginEnd="2dp"/>

                <!-- Delete -->
                <ImageButton
                    android:id="@+id/btnDelete"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:src="@drawable/ic_delete"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    app:tint="@color/primary_light"/>

            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
