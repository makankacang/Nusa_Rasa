<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="14dp">

        <!-- Thumbnail: ImageView + emoji fallback -->
        <FrameLayout
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:background="#FFF0EE">

            <!-- Gambar dari server -->
            <ImageView
                android:id="@+id/imgMenuCart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:visibility="gone"
                android:contentDescription="@null" />

            <!-- Emoji fallback -->
            <TextView
                android:id="@+id/tvEmojiCart"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="🍗"
                android:textSize="24sp"
                android:visibility="visible" />

        </FrameLayout>

        <!-- Nama + Harga -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvNamaCart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Ayam"
                android:textStyle="bold"
                android:textSize="15sp" />

            <TextView
                android:id="@+id/tvHargaCart"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 25.000"
                android:textColor="@color/primary_red"
                android:textStyle="bold" />

        </LinearLayout>

        <!-- Qty control -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:background="@drawable/bg_qty_control">

            <TextView
                android:id="@+id/btnMinusCart"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="−"
                android:textColor="@color/primary_red"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvQtyCart"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="1"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/btnPlusCart"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:gravity="center"
                android:text="+"
                android:textColor="@color/primary_red"
                android:textStyle="bold" />

        </LinearLayout>

    </LinearLayout>

</androidx.cardview.widget.CardView>
