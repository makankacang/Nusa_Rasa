<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary_red">

    <!-- Lingkaran dekorasi kanan atas -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:background="@drawable/bg_circle_overlay"
        android:alpha="0.08"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Lingkaran dekorasi kiri bawah -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="@drawable/bg_circle_overlay"
        android:alpha="0.06"
        android:layout_marginBottom="-40dp"
        android:layout_marginStart="-40dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Konten tengah -->
    <LinearLayout
        android:id="@+id/centerContent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/dotsLayout"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Logo bulat dengan shadow -->

        <!-- Nama App -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="28dp"
            android:fontFamily="sans-serif-black"
            android:letterSpacing="0.12"
            android:text="NUSA RASA"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <!-- Garis pemisah -->
        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:background="#80FFFFFF"
            android:layout_gravity="center" />

        <!-- Subtitle -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Taliwang Nyawang"
            android:textColor="#CCFFFFFF"
            android:textSize="15sp"
            android:letterSpacing="0.06"
            android:fontFamily="sans-serif-light" />

    </LinearLayout>

    <!-- Dots loading di bawah -->
    <LinearLayout
        android:id="@+id/dotsLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="64dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Dot aktif -->
        <View
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:background="@drawable/bg_dot_active"
            android:layout_marginEnd="6dp" />

        <!-- Dot tidak aktif 1 -->
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot_inactive"
            android:layout_marginEnd="6dp" />

        <!-- Dot tidak aktif 2 -->
        <View
            android:layout_width="8dp"
            android:layout_height="8dp"
            android:background="@drawable/bg_dot_inactive" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>