<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".admin">

    <ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/white">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="170dp"
                android:orientation="vertical"
                android:padding="22dp"
                android:background="@color/primary_red">

                <TextView
                    android:text="Admin"
                    android:textColor="@color/white"
                    android:textSize="14sp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:text="Dashboard Pesanan"
                    android:textColor="@color/white"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="18dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="5\nPending"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_rounded"/>

                    <Space android:layout_width="10dp" android:layout_height="1dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="12\nDiproses"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_rounded"/>

                    <Space android:layout_width="10dp" android:layout_height="1dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="70dp"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:text="28\nSelesai"
                        android:textColor="@color/white"
                        android:background="@drawable/bg_red_rounded"/>

                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_margin="20dp"
                android:padding="18dp"
                android:background="@drawable/bg_soft_red"
                android:text="#ORD-001 - Meja 3\nBudi Santoso - 2 menit lalu\n\nAyam Taliwang x1     Rp 25.000\nNasi Plecing x2      Rp 36.000\n\nTotal                Rp 64.050"
                android:textSize="15sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="20dp"
                android:paddingEnd="20dp"
                android:orientation="horizontal">

                <Button
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Setujui"
                    android:backgroundTint="@color/primary_red"
                    android:textColor="@color/white"/>

                <Space android:layout_width="12dp" android:layout_height="1dp"/>

                <Button
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Tolak"
                    android:backgroundTint="#EEEEEE"
                    android:textColor="@color/text_dark"/>
            </LinearLayout>

        </LinearLayout>

    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>