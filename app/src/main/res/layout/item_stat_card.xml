<?xml version="1.0" encoding="utf-8"?>
<!--
    Item kartu statistik untuk Dashboard.
    Gunakan via <include> dan set value dari Activity:
        statTotalOrders.findViewById<TextView>(R.id.tvStatLabel).text = "Total Pesanan"
        statTotalOrders.findViewById<TextView>(R.id.tvStatValue).text = "24"
-->
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="12dp"
    app:cardElevation="1dp"
    app:cardBackgroundColor="@color/surface_card">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- Icon + Label row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/tvStatLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Label"
                android:textSize="10sp"
                android:textAllCaps="true"
                android:letterSpacing="0.07"
                android:textColor="@color/text_secondary"/>

            <ImageView
                android:id="@+id/ivStatIcon"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_orders"
                app:tint="@color/primary"/>
        </LinearLayout>

        <!-- Value -->
        <TextView
            android:id="@+id/tvStatValue"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"/>

        <!-- Optional subtitle -->
        <TextView
            android:id="@+id/tvStatSub"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text=""
            android:textSize="10sp"
            android:textColor="@color/text_tertiary"
            android:visibility="gone"/>

    </LinearLayout>
</androidx.cardview.widget.CardView>
